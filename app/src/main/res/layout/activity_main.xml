<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tb_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bluePrimary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_umur"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Masukkan Umur"
        android:layout_marginTop="20dp"
        android:layout_marginStart="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tb_main" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_umur"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="136dp"
        app:layout_constraintStart_toStartOf="@id/tv_umur"
        app:layout_constraintTop_toBottomOf="@id/tv_umur">

            <EditText
                android:id="@+id/et_umur"
                android:inputType="number"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:hint="Cnt: 12"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tv_jk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Masukkan Jenis Kelamin dengan angka"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/til_umur"
        app:layout_constraintStart_toStartOf="@id/til_umur" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_jk"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="136dp"
        app:layout_constraintStart_toStartOf="@id/tv_jk"
        app:layout_constraintTop_toBottomOf="@id/tv_jk">

        <EditText
            android:id="@+id/et_jk"
            android:inputType="number"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:hint="0: laki-laki, 1: perempuan"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tv_tinggi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tinggi Badan (cm)"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/til_jk"
        app:layout_constraintStart_toStartOf="@id/til_jk" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_tinggi"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="136dp"
        app:layout_constraintStart_toStartOf="@id/tv_tinggi"
        app:layout_constraintTop_toBottomOf="@id/tv_tinggi">

        <EditText
            android:id="@+id/et_tinggi"
            android:inputType="number"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:hint="Cnth: 90" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btn_submit"
        android:layout_width="170dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/blueSecond"
        android:text="Kirim"
        app:layout_constraintStart_toStartOf="@id/til_tinggi"
        app:layout_constraintTop_toBottomOf="@id/til_tinggi" />

    <TextView
        android:id="@+id/tv_normal_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="data normal"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toEndOf="@id/btn_submit"
        app:layout_constraintTop_toBottomOf="@id/til_tinggi"/>

    <TextView
        android:id="@+id/tv_number_normal_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="6"
        android:textColor="@color/green"
        android:layout_marginStart="5dp"
        app:layout_constraintStart_toEndOf="@+id/tv_normal_data"
        app:layout_constraintTop_toTopOf="@id/tv_normal_data" />

    <TextView
        android:id="@+id/tv_stunting_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="data stunting"
        app:layout_constraintStart_toEndOf="@id/btn_submit"
        app:layout_constraintTop_toBottomOf="@id/tv_normal_data" />

    <TextView
        android:id="@+id/tv_number_stunting_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="6"
        android:textColor="@color/red"
        android:layout_marginStart="5dp"
        app:layout_constraintStart_toEndOf="@id/tv_stunting_data"
        app:layout_constraintTop_toTopOf="@id/tv_stunting_data" />

    <TextView
        android:id="@+id/tv_total_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="20sp"
        tools:text="total data"
        app:layout_constraintStart_toStartOf="@id/tv_stunting_data"
        app:layout_constraintTop_toBottomOf="@id/tv_stunting_data"/>

    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/rv_item_list"
        app:layout_constraintTop_toBottomOf="@id/tv_total_data">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:text="Tanggal"
            android:layout_marginEnd="45dp" />
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Umur"
            android:layout_marginEnd="35dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JK"
            android:textStyle="bold"
            android:layout_marginEnd="45dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Tinggi"
            android:layout_marginEnd="35dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Hasil"
            android:layout_marginEnd="5dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_item_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_header" />

</androidx.constraintlayout.widget.ConstraintLayout>