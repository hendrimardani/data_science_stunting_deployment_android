            <ImageView
                android:id="@+id/iv_nama_ortu"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/ic_orang_tua"
                app:layout_constraintEnd_toStartOf="@id/til_nama_ortu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_tinggi_anak" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_nama_ortu"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:elevation="5dp"
                android:hint="Nama orang tua"
                app:boxBackgroundColor="@color/white"
                app:boxStrokeColor="@color/blueSecond_200"
                app:endIconMode="clear_text"
                app:endIconTint="@color/red"
                app:layout_constraintBottom_toBottomOf="@id/iv_nama_ortu"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_nama_ortu"
                app:layout_constraintTop_toTopOf="@id/iv_nama_ortu"
                app:shapeAppearance="@style/Rounded">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_nama_ortu_anak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

        <Button
                android:id="@+id/btn_submit_anak"
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                app:strokeColor="@color/blueSecond"
                app:icon="@drawable/ic_send_to_mobile_24px"
                android:paddingHorizontal="30dp"
                app:layout_constraintTop_toBottomOf="@id/iv_nama_ortu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_tampil_data_anak"
                android:text="Kirim" />

        <Button
            android:id="@+id/btn_tampil_data_anak"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.Button.Icon"
            app:strokeColor="@color/blueSecond"
            app:icon="@drawable/ic_visibility_24px"
            android:text="Tampilkan Data"
            android:paddingHorizontal="@dimen/dimen_16"
            android:layout_marginStart="@dimen/dimen_8"
            app:layout_constraintBottom_toBottomOf="@+id/btn_submit_anak"
            app:layout_constraintStart_toEndOf="@+id/btn_submit_anak"
            app:layout_constraintTop_toTopOf="@+id/btn_submit_anak"
            app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>