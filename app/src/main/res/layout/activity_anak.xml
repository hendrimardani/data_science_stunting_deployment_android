<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:id="@+id/main">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbarLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:collapsedTitleTextColor="@color/white"
            app:contentScrim="?attr/colorPrimary"
            app:expandedTitleMarginStart="48dp"
            app:expandedTitleMarginEnd="64dp">

            <ImageView
                android:id="@+id/toolbarImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:fitsSystemWindows="true"
                android:src="@drawable/kartun_anak_anak_blur"
                app:layout_collapseMode="parallax" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/child_service_form"
                android:textSize="36dp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:shadowColor="#000000"
                android:shadowDx="10"
                android:shadowDy="10"
                android:shadowRadius="10" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/tbAnak"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
                app:layout_collapseMode="pin" />
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Fungsi dari
    android:fitsSystemWindows="true"
 supaya editText muncul diatas keyboard -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/iv_name"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/ic_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/til_nama_anak"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_nama_anak"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:elevation="5dp"
                    android:hint="Nama anda"
                    app:boxBackgroundColor="@color/white"
                    app:boxStrokeColor="@color/blueSecond_200"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/red"
                    app:layout_constraintBottom_toBottomOf="@id/iv_name"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iv_name"
                    app:layout_constraintTop_toTopOf="@id/iv_name"
                    app:shapeAppearance="@style/Rounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nama_anak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageView
                    android:id="@+id/iv_jk"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/ic_jk"
                    app:layout_constraintEnd_toStartOf="@id/til_jk"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_name" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_jk"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:elevation="5dp"
                    android:hint="Jenis kelamin (0: L, 1: P)"
                    app:boxBackgroundColor="@color/white"
                    app:boxStrokeColor="@color/blueSecond_200"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/red"
                    app:layout_constraintBottom_toBottomOf="@id/iv_jk"
                    app:layout_constraintStart_toEndOf="@id/iv_jk"
                    app:layout_constraintTop_toTopOf="@id/iv_jk"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:shapeAppearance="@style/Rounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_jk_anak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageView
                    android:id="@+id/iv_nik"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/ic_nik"
                    app:layout_constraintEnd_toStartOf="@id/til_nik"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_jk" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_nik"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:elevation="5dp"
                    android:hint="Nomor Induk Kependudukan"
                    app:boxBackgroundColor="@color/white"
                    app:boxStrokeColor="@color/blueSecond_200"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/red"
                    app:layout_constraintBottom_toBottomOf="@id/iv_nik"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iv_nik"
                    app:layout_constraintTop_toTopOf="@id/iv_nik"
                    app:shapeAppearance="@style/Rounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nik_anak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageView
                    android:id="@+id/iv_tgl_lahir_anak"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/ic_tgl_lahir"
                    app:layout_constraintEnd_toStartOf="@id/til_tgl_lahir_anak"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_nik" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_tgl_lahir_anak"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:elevation="5dp"
                    android:hint="Tanggal lahir"
                    app:boxBackgroundColor="@color/white"
                    app:boxStrokeColor="@color/bluePrimary"
                    app:endIconMode="clear_text"
                    app:endIconTint="@color/red"
                    app:layout_constraintBottom_toBottomOf="@id/iv_tgl_lahir_anak"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/iv_tgl_lahir_anak"
                    app:layout_constraintTop_toTopOf="@id/iv_tgl_lahir_anak"
                    app:shapeAppearance="@style/Rounded">

                    <!--- Atur atribut bernama foucsable dan focusableInTouchMode ke false supaya dateTime Calendar aktif
                        android:focusable="false"
                        android:focusableInTouchMode="false" -->
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_tgl_anak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:inputType="datetime" />
                </com.google.android.material.textfield.TextInputLayout>

            <ImageView
                android:id="@+id/iv_umur_anak"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/ic_umur"
                app:layout_constraintEnd_toStartOf="@id/til_umur_anak"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_tgl_lahir_anak" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_umur_anak"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:elevation="5dp"
                android:hint="Umur (dalam bulan)"
                app:boxBackgroundColor="@color/white"
                app:boxStrokeColor="@color/blueSecond_200"
                app:endIconMode="clear_text"
                app:endIconTint="@color/red"
                app:layout_constraintBottom_toBottomOf="@id/iv_umur_anak"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_umur_anak"
                app:layout_constraintTop_toTopOf="@id/iv_umur_anak"
                app:shapeAppearance="@style/Rounded">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_umur_anak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

