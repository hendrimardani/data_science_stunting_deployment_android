<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_bottom_sheet_dialog"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/iv_rectangle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/shape_rectangle"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_data_bumil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="List Data Bumil"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="100dp"
            android:layout_marginEnd="80dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_rectangle"
            app:layout_constraintEnd_toStartOf="@id/iv_delete"/>

        <ImageView
            android:id="@+id/iv_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_delete"
            app:layout_constraintStart_toEndOf="@id/tv_data_bumil"
            app:layout_constraintTop_toTopOf="@id/tv_data_bumil"
            app:layout_constraintEnd_toEndOf="@id/tv_data_bumil"
            app:layout_constraintBottom_toBottomOf="@id/tv_data_bumil"/>

        <TextView
            android:id="@+id/tv_header_tanggal_input"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tanggal Input"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_data_bumil" />

        <TextView
            android:id="@+id/tv_header_nik"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NIK"
            android:textStyle="bold"
            android:layout_marginStart="70dp"
            app:layout_constraintStart_toEndOf="@id/tv_header_tanggal_input"
            app:layout_constraintTop_toTopOf="@id/tv_header_tanggal_input"
            app:layout_constraintBottom_toBottomOf="@id/tv_header_tanggal_input" />

        <TextView
            android:id="@+id/tv_header_nama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama"
            android:textStyle="bold"
            android:layout_marginStart="120dp"
            app:layout_constraintStart_toEndOf="@id/tv_header_nik"
            app:layout_constraintTop_toTopOf="@+id/tv_header_nik"
            app:layout_constraintBottom_toBottomOf="@id/tv_header_nik" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_bottom_sheet_bumil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:rotationX="-360"
            android:visibility="visible"
            tools:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/tv_header_tanggal_input"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>